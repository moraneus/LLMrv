# TemporalGuard — Environment Variables
# Copy this file to .env and fill in your values.

# OpenRouter (chat model)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_MODEL_CUSTOM=            # Optional: override dropdown with any model ID

# Grounding LLM
GROUNDING_PROVIDER=ollama          # ollama | lmstudio | vllm | custom | openrouter
GROUNDING_BASE_URL=http://localhost:11434
GROUNDING_MODEL=mistral
GROUNDING_API_KEY=                  # Optional: separate API key for OpenRouter grounding

# Database
DATABASE_PATH=./temporalguard.db

# Server
HOST=0.0.0.0
PORT=8000
